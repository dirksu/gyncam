### Example /etc/default/gyncam
# User and group used for the systemd unit should match the service file.
# Set GYNCAM_ARGS to any args you want to pass to gyncam.py. Examples:
#  --no-fullscreen --snap-button --source-text "" --device /dev/video0
# Example below uses framebuffer defaults for Raspberry Pi.

# Camera device and preview size
GYNCAM_ARGS='--device 0 --width 0 --height 0 --fps 0'

# Run in fullscreen (default true). Use --no-fullscreen to disable.
# GYNCAM_ARGS="$GYNCAM_ARGS --fullscreen"

# Optional: override source overlay text (empty disables)
# GYNCAM_ARGS="$GYNCAM_ARGS --source-text 'Dirk Sudowe Praxis für Frauenheilkunde Voerde'"

# Optional: touch/mouse device if you add evdev handler (not implemented here)
# TOUCH_DEV=/dev/input/event0

# Environment variables for SDL/framebuffer (example)
SDL_VIDEODRIVER=fbcon
SDL_FBDEV=/dev/fb0
SDL_MOUSEDRV=TSLIB
SDL_MOUSEDEV=/dev/input/touchscreen
