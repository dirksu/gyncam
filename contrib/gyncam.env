### Example /etc/default/gyncam
# User and group used for the systemd unit should match the service file.
# Set GYNCAM_ARGS to any args you want to pass to gyncam.py. Examples:
#  --no-fullscreen --snap-button --source-text "" --device /dev/video0
# Example below uses framebuffer defaults for Raspberry Pi.

# Camera device and preview size
GYNCAM_ARGS='--device 0 --width 0 --height 0 --fps 0'

# Run in fullscreen (default true). Use --no-fullscreen to disable.
# GYNCAM_ARGS="$GYNCAM_ARGS --fullscreen"

# Optional: override source overlay text (empty disables)
# GYNCAM_ARGS="$GYNCAM_ARGS --source-text 'Dirk Sudowe Praxis für Frauenheilkunde Voerde'"

# Optional: touch/mouse device if you add evdev handler (not implemented here)
# TOUCH_DEV=/dev/input/event0

# Environment variables for SDL/framebuffer (example)
SDL_VIDEODRIVER=fbcon
SDL_FBDEV=/dev/fb0
SDL_MOUSEDRV=TSLIB
SDL_MOUSEDEV=/dev/input/touchscreen
# OpenCV log level (ERROR, WARNING, INFO, DEBUG). Set to ERROR to reduce noise.
OPENCV_LOG_LEVEL=ERROR
# XDG_RUNTIME_DIR may be required by some libraries (dbus/pipewire). When running
# under systemd the service unit can create a runtime dir (see contrib/gyncam.service).
# If you run gyncam directly, you can set this to a writable path, e.g. /tmp/gyncam
# or /run/user/1000 when available.
# XDG_RUNTIME_DIR=/run/gyncam

# --- All supported environment variables (defaults) ---
# Camera
# CAM_DEVICE=0
# CAM_WIDTH=0
# CAM_HEIGHT=0
# CAM_FPS=0
# CAM_ROTATE=0

# Output
# LOCAL_OUT=/var/lib/gyncam
# REMOTE_PREFIX=

# SMB
# SMB_MOUNT_PATH=
# SMB_SHARE=//server/share
# SMB_REMOTE_DIR=
# SMB_USER=
# SMB_PASS=
# SMB_DOMAIN=
# SMB_AUTHFILE=

# UI
# FULLSCREEN=1
# SNAP_BUTTON=1

# GPIO
# GPIO_ENABLE=0
# GPIO_PIN=17
# GPIO_PULL=up
# GPIO_EDGE=falling
# GPIO_BOUNCE_MS=200

# Notes: CLI flags override environment variables. Boolean env values accept
# 1/0, true/false, yes/no, on/off (case-insensitive).

# Advanced
# FORCE_GST=0
# VERBOSE_CAPTURE=0
