### Example /etc/default/gyncam
# User and group used for the systemd unit should match the service file.
# Set GYNCAM_ARGS to any args you want to pass to gyncam.py. Examples:
#  --no-fullscreen --snap-button --source-text "" --device /dev/video0
# Example below uses framebuffer defaults for Raspberry Pi.

# Camera device and preview size (defaults: device 0, no forced capture size)
GYNCAM_ARGS='--device 0 --width 0 --height 0 --fps 0'

# Run in fullscreen (default true). Use --no-fullscreen to disable.
# GYNCAM_ARGS="$GYNCAM_ARGS --fullscreen"

# Optional: override source overlay text (empty disables)
# GYNCAM_ARGS="$GYNCAM_ARGS --source-text 'Dirk Sudowe Praxis für Frauenheilkunde Voerde'"

# Optional: touch/mouse device if you add evdev handler
# TOUCH_DEV=/dev/input/event0

# Framebuffer / SDL example environment (use when running on Raspberry Pi framebuffer)
SDL_VIDEODRIVER=fbcon
SDL_FBDEV=/dev/fb0
SDL_MOUSEDRV=TSLIB
SDL_MOUSEDEV=/dev/input/touchscreen

# OpenCV log level (ERROR, WARNING, INFO, DEBUG). Default in code: ERROR
OPENCV_LOG_LEVEL=ERROR

# Some libraries (PipeWire/dbus) may require XDG_RUNTIME_DIR. When running under
# systemd the service file can create a runtime dir (see contrib/gyncam.service).
# If running manually you can set this to a writable path, e.g. /tmp/gyncam
# XDG_RUNTIME_DIR=/run/gyncam

# --- Supported environment variables (with typical defaults) ---
# Camera
# CAM_DEVICE=0          # camera index (or /dev/videoN)
# CAM_WIDTH=0           # snapshot capture width (0 = do not force)
# CAM_HEIGHT=0          # snapshot capture height (0 = do not force)
# CAM_FPS=0             # desired fps for capture negotiation (0 = driver default)
# CAM_ROTATE=0          # 0,90,180,270 rotate frames before display/save

# Preview / display
# PREVIEW_WIDTH=0       # preview stream width (0 = use display resolution)
# PREVIEW_HEIGHT=0      # preview stream height (0 = use display resolution)

# Output
# LOCAL_OUT=/var/lib/gyncam    # local directory where snapshots are saved
# REMOTE_PREFIX=               # optional prefix (folder-ish) added to remote filename

# SMB / upload
# SMB_MOUNT_PATH=              # if set: copy snapshots to this local mount path
# SMB_SHARE=//server/share     # smbclient target (used when SMB_MOUNT_PATH is empty)
# SMB_REMOTE_DIR=              # remote directory inside the share
# SMB_USER=                    # username for smbclient (unless using SMB_AUTHFILE)
# SMB_PASS=                    # password for smbclient (unless using SMB_AUTHFILE)
# SMB_DOMAIN=                  # domain/workgroup (optional)
# SMB_AUTHFILE=/path/to/auth   # authfile for smbclient -A (see README for format)

# UI
# FULLSCREEN=1        # 1/0 or true/false: start in fullscreen (default: 1)
# SNAP_BUTTON=1       # show on-screen SNAP button (default: 1)

# GPIO (optional hardware button)
# GPIO_ENABLE=0       # enable GPIO trigger (0/1)
# GPIO_PIN=17         # BCM pin number
# GPIO_PULL=up        # up/down/off
# GPIO_EDGE=falling   # rising/falling/both
# GPIO_BOUNCE_MS=200  # debounce in ms

# Pixel format negotiation
# CAM_PIX_FMT=auto    # preferred camera pixel format for preview/snap negotiation
#                     # (auto, mjpeg/mjpg, yuy2)
# SNAP_PIX_FMT=auto   # preferred pixel format used when opening temporary snap capture

# Beep feedback
# BEEP=1              # enable short beep on snapshot (1/0)

# Advanced / diagnostics
# FORCE_GST=0         # force using GStreamer pipeline for capture negotiation
# VERBOSE_CAPTURE=0   # verbose capture negotiation logging

# Notes:
# - CLI flags override environment variables.
# - Boolean env values accept 1/0, true/false, yes/no, on/off (case-insensitive).
# - When using SMB authfile, ensure it's readable only by the running account (chmod 600).
